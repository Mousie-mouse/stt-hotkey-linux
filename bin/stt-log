#!/bin/bash

OUTPUT_DIR="${STT_OUTPUT_DIR:-$HOME/stt-output}"

mkdir -p "$OUTPUT_DIR"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "STT Output" "$1" >/dev/null 2>&1 || true
    fi
}

if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$OUTPUT_DIR" >/dev/null 2>&1 &
    notify "Opened $OUTPUT_DIR"
    exit 0
fi

if command -v x-terminal-emulator >/dev/null 2>&1; then
    STT_OUTPUT_DIR="$OUTPUT_DIR" x-terminal-emulator -e bash -c 'echo "--- STT OUTPUT ---"; echo "$STT_OUTPUT_DIR"; echo; ls -lt "$STT_OUTPUT_DIR"; echo; read -p "Press enter to close..."'
    exit 0
fi

printf '%s\n' "$OUTPUT_DIR"
ls -lt "$OUTPUT_DIR"
