#!/bin/bash

FILE="/tmp/whisper_stt/last_transcript.txt"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "STT" "$1" >/dev/null 2>&1 || true
    fi
}

if [ ! -s "$FILE" ]; then
    notify "No saved transcript"
    exit 1
fi

cat "$FILE" | xclip -selection clipboard
notify "Last transcript copied"
