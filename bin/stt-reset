#!/bin/bash

TMP_DIR="/tmp/whisper_stt"
mkdir -p "$TMP_DIR"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "STT" "$1" >/dev/null 2>&1 || true
    fi
}

notify "Resetting..."

# Stop any active recording
pkill -INT arecord 2>/dev/null

# Clean state
rm -f "$TMP_DIR/arecord.pid"
rm -f "$TMP_DIR/record.wav"
rm -f "$TMP_DIR/last_run.log"

# Reset to English defaults
printf '%s' "en" > "$TMP_DIR/current_language"
printf '%s' "$HOME/whisper.cpp/models/ggml-base.en.bin" > "$TMP_DIR/current_model"
: > "$TMP_DIR/current_extra"

notify "Reset complete → English"
