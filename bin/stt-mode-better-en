#!/bin/bash

TMP_DIR="/tmp/whisper_stt"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "STT" "$1" >/dev/null 2>&1 || true
    fi
}

printf '%s' "en" > "$TMP_DIR/current_language"
printf '%s' "$HOME/whisper.cpp/models/ggml-small.en.bin" > "$TMP_DIR/current_model"
: > "$TMP_DIR/current_extra"

notify "Mode: better English (small.en)"
