#!/bin/bash
set -euo pipefail

TMP_DIR="/tmp/whisper_stt"
TEST_DIR="$HOME/stt-audio-tests"
AUDIO_DIR="$TEST_DIR/audio"
TRANSCRIPT_DIR="$TEST_DIR/transcripts"

mkdir -p "$AUDIO_DIR" "$TRANSCRIPT_DIR"

BASE_MODEL="$HOME/whisper.cpp/models/ggml-base.en.bin"
SMALL_MODEL="$HOME/whisper.cpp/models/ggml-small.en.bin"

BIN="$HOME/whisper.cpp/build/bin/whisper-cli"

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "STT Compare" "$1" >/dev/null 2>&1 || true
    fi
}

ensure_model() {
    local model_name="$1"
    local model_path="$2"
    local whisper_dir="$HOME/whisper.cpp"

    if [ -f "$model_path" ]; then
        return 0
    fi

    if [ -t 0 ] && [ -t 1 ]; then
        echo
        echo "Required model is not installed: $model_name"
        echo "Install now? [y/N]"
        read -r reply
        case "$reply" in
            y|Y|yes|YES)
                cd "$whisper_dir"
                bash ./models/download-ggml-model.sh "$model_name"
                ;;
            *)
                echo "Cancelled."
                return 1
                ;;
        esac
    else
        notify "Model '$model_name' missing. Run install in terminal."
        return 1
    fi

    [ -f "$model_path" ]
}

# Ensure models
ensure_model "base.en" "$BASE_MODEL" || exit 1
ensure_model "small.en" "$SMALL_MODEL" || exit 1

# Input file
INPUT_FILE="${1:-$TMP_DIR/record.wav}"

if [ ! -f "$INPUT_FILE" ]; then
    echo "No input audio found."
    exit 1
fi

TIMESTAMP=$(date +%s)

BASE_OUT="$TRANSCRIPT_DIR/base-$TIMESTAMP.txt"
SMALL_OUT="$TRANSCRIPT_DIR/small-$TIMESTAMP.txt"

echo "Running base.en..."
BASE_TEXT="$($BIN -m "$BASE_MODEL" -f "$INPUT_FILE" -l en 2>/dev/null | sed -E 's/\[[^]]*\][[:space:]]*//g')"
echo "$BASE_TEXT" > "$BASE_OUT"

echo "Running small.en..."
SMALL_TEXT="$($BIN -m "$SMALL_MODEL" -f "$INPUT_FILE" -l en 2>/dev/null | sed -E 's/\[[^]]*\][[:space:]]*//g')"
echo "$SMALL_TEXT" > "$SMALL_OUT"

echo
echo "=== base.en ==="
echo "$BASE_TEXT"
echo
echo "=== small.en ==="
echo "$SMALL_TEXT"

# Copy better result (small)
if command -v xclip >/dev/null 2>&1; then
    printf '%s' "$SMALL_TEXT" | xclip -selection clipboard
fi

notify "Comparison complete (small copied)"
